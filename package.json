{
  "name": "gridcalc",
  "version": "0.0.1",
  "description": "Headless, Excel-compatible formula engine for TypeScript. Zero runtime dependencies.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests scripts",
    "generate-fixtures": "tsx scripts/generate-fixtures.ts",
    "bench": "tsx scripts/benchmark.ts",
    "site:build": "npm run build && cp dist/index.js site/gridcalc.js && tsx scripts/generate-site-docs.ts",
    "site:serve": "npm run site:build && python3 -m http.server 4173 -d site"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
